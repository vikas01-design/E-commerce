ded-2xl backdrop-blur-md border border-white/5 group\" data-kid=\"97\">\n        <div class=\"relative overflow-hidden rounded-xl mb-4 h-64\" data-kid=\"98\">\n          <img src=\"https://images.unsplash.com/photo-1617627143750-d86bc21e42bb?w=400&fit=crop\" class=\"w-full h-full object-cover transition-transform group-hover:scale-110\" data-kid=\"99\">\n          <div class=\"absolute top-4 right-4 bg-(--color-obsidian) px-3 py-1 rounded text-xs font-bold\" data-kid=\"100\">SALE</div>\n        </div>\n        <h4 class=\"font-cinzel text-lg uppercase truncate\" data-kid=\"101\">Banarasi Silk</h4>\n        <div class=\"flex items-center justify-between\" data-kid=\"102\">\n          <p class=\"text-white/60 line-through text-sm\" data-kid=\"103\">₹8,999</p>\n          <p class=\"text-xl font-bold\" data-kid=\"104\">₹6,999</p>\n        </div>\n      </div>\n      \n      <div class=\"bg-black/20 p-6 rounded-2xl backdrop-blur-md border border-white/5 group mt-12\" data-kid=\"105\">\n        <div class=\"relative overflow-hidden rounded-xl mb-4 h-64\" data-kid=\"106\">\n          <img src=\"https://images.unsplash.com/photo-1566174053879-31528523f8ae?w=400&fit=crop\" class=\"w-full h-full object-cover transition-transform group-hover:scale-110\" data-kid=\"107\">\n          <div class=\"absolute top-4 right-4 bg-(--color-obsidian) px-3 py-1 rounded text-xs font-bold\" data-kid=\"108\">HOT</div>\n        </div>\n        <h4 class=\"font-cinzel text-lg uppercase truncate\" data-kid=\"109\">Party Gown</h4>\n        <div class=\"flex items-center justify-between\" data-kid=\"110\">\n          <p class=\"text-white/60 line-through text-sm\" data-kid=\"111\">₹5,500</p>\n          <p class=\"text-xl font-bold\" data-kid=\"112\">₹3,999</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 px-12 bg-(--color-obsidian)\" data-kid=\"113\">\n  <div class=\"text-center mb-24\" data-kid=\"114\">\n    <h2 class=\"font-cinzel text-5xl uppercase tracking-[0.2em] mb-4\" data-kid=\"115\">High Demand</h2>\n    <p class=\"text-white/40 font-light tracking-[0.5em] uppercase\" data-kid=\"116\">Pieces vanishing from the archive</p>\n  </div>\n\n  <div class=\"grid grid-cols-1 md:grid-cols-3 gap-16\" data-kid=\"117\">\n    \n    <div class=\"relative group bg-white/5 p-8 rounded-3xl overflow-hidden border border-white/5\" data-kid=\"118\">\n      <div class=\"rising-demand\" style=\"height: 85%;\" data-kid=\"119\"></div>\n      <div class=\"relative z-10\" data-kid=\"120\">\n        <div class=\"flex justify-between items-start mb-8\" data-kid=\"121\">\n          <img src=\"https://images.unsplash.com/photo-1617627143750-d86bc21e42bb?w=100&h=100&fit=crop\" class=\"w-20 h-20 rounded-xl object-cover grayscale\" data-kid=\"122\">\n          <span class=\"text-sm font-bold text-(--color-crimson)\" data-kid=\"123\">85% SOLD</span>\n        </div>\n        <h3 class=\"font-cinzel text-2xl uppercase mb-2\" data-kid=\"124\">Banarasi Silk</h3>\n        <p class=\"text-xs text-white/50 tracking-widest uppercase mb-8\" data-kid=\"125\">Only 4 pieces remaining</p>\n        <button class=\"w-full py-4 bg-white text-black text-xs font-bold uppercase tracking-widest hover:bg-(--color-crimson) hover:text-white transition-colors rounded-lg\" data-kid=\"126\">Secure Access</button>\n      </div>\n    </div>\n    \n    <div class=\"relative group bg-white/5 p-8 rounded-3xl overflow-hidden border border-white/5\" data-kid=\"127\">\n      <div class=\"rising-demand\" style=\"height: 72%;\" data-kid=\"128\"></div>\n      <div class=\"relative z-10\" data-kid=\"129\">\n        <div class=\"flex justify-between items-start mb-8\" data-kid=\"130\">\n          <img src=\"https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=100&h=100&fit=crop\" class=\"w-20 h-20 rounded-xl object-cover grayscale\" data-kid=\"131\">\n          <span class=\"text-sm font-bold text-(--color-crimson)\" data-kid=\"132\">72% SOLD</span>\n        </div>\n        <h3 class=\"font-cinzel text-2xl uppercase mb-2\" data-kid=\"133\">Dhoti Kurta Set</h3>\n        <p class=\"text-xs text-white/50 tracking-widest uppercase mb-8\" data-kid=\"134\">Rapidly depleting</p>\n        <button class=\"w-full py-4 bg-white text-black text-xs font-bold uppercase tracking-widest hover:bg-(--color-crimson) hover:text-white transition-colors rounded-lg\" data-kid=\"135\">Secure Access</button>\n      </div>\n    </div>\n    \n    <div class=\"relative group bg-white/5 p-8 rounded-3xl overflow-hidden border border-white/5\" data-kid=\"136\">\n      <div class=\"rising-demand\" style=\"height: 94%;\" data-kid=\"137\"></div>\n      <div class=\"relative z-10\" data-kid=\"138\">\n        <div class=\"flex justify-between items-start mb-8\" data-kid=\"139\">\n          <img src=\"https://images.unsplash.com/photo-1572804013309-59a88b7e92f1?w=100&h=100&fit=crop\" class=\"w-20 h-20 rounded-xl object-cover grayscale\" data-kid=\"140\">\n          <span class=\"text-sm font-bold text-(--color-crimson)\" data-kid=\"141\">94% SOLD</span>\n        </div>\n        <h3 class=\"font-cinzel text-2xl uppercase mb-2\" data-kid=\"142\">Printed Maxi</h3>\n        <p class=\"text-xs text-white/50 tracking-widest uppercase mb-8\" data-kid=\"143\">Final piece in stock</p>\n        <button class=\"w-full py-4 bg-white text-black text-xs font-bold uppercase tracking-widest hover:bg-(--color-crimson) hover:text-white transition-colors rounded-lg\" data-kid=\"144\">Secure Access</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 px-12 bg-black\" data-kid=\"145\">\n  <div class=\"text-center mb-32\" data-kid=\"146\">\n    <h2 class=\"font-cinzel text-8xl uppercase tracking-tighter opacity-10\" data-kid=\"147\">THE REVEAL</h2>\n    <h2 class=\"font-cinzel text-5xl uppercase tracking-[0.2em] -mt-16 relative z-10\" data-kid=\"148\">Season Premiere</h2>\n  </div>\n\n  <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 max-w-screen-2xl mx-auto\" data-kid=\"149\">\n    \n    <div class=\"group cursor-pointer\" data-kid=\"150\">\n      <div class=\"relative h-[700px] overflow-hidden mb-8 border border-white/10\" data-kid=\"151\">\n        <div class=\"absolute top-0 left-0 w-full p-8 z-10 pointer-events-none\" data-kid=\"152\">\n          <p class=\"font-cinzel text-5xl leading-none opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"153\">01</p>\n          <h3 class=\"font-cinzel text-4xl uppercase tracking-tighter -mt-2 group-hover:text-(--color-crimson) transition-colors\" data-kid=\"154\">Organza<br data-kid=\"155\">Ruffle</h3>\n        </div>\n        <img src=\"https://images.unsplash.com/photo-1515372039744-b8f02a3ae446?w=600&h=900&fit=crop\" class=\"w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 brightness-50 group-hover:brightness-100 group-hover:grayscale-0 grayscale\" decoding=\"async\" loading=\"lazy\" data-kid=\"156\">\n        <div class=\"absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black to-transparent\" data-kid=\"157\">\n          <button class=\"font-cinzel uppercase tracking-widest text-sm border border-white px-8 py-3 group-hover:bg-white group-hover:text-black transition-all\" data-kid=\"158\">Explore Look</button>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"group cursor-pointer mt-24\" data-kid=\"159\">\n      <div class=\"relative h-[700px] overflow-hidden mb-8 border border-white/10\" data-kid=\"160\">\n        <div class=\"absolute top-0 left-0 w-full p-8 z-10 pointer-events-none\" data-kid=\"161\">\n          <p class=\"font-cinzel text-5xl leading-none opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"162\">02</p>\n          <h3 class=\"font-cinzel text-4xl uppercase tracking-tighter -mt-2 group-hover:text-(--color-crimson) transition-colors\" data-kid=\"163\">Kaftan<br data-kid=\"164\">Breeze</h3>\n        </div>\n        <img src=\"https://images.unsplash.com/photo-1596755094514-f87e34085b2c?w=600&h=900&fit=crop\" class=\"w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 brightness-50 group-hover:brightness-100 group-hover:grayscale-0 grayscale\" decoding=\"async\" loading=\"lazy\" data-kid=\"165\">\n        <div class=\"absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black to-transparent\" data-kid=\"166\">\n          <button class=\"font-cinzel uppercase tracking-widest text-sm border border-white px-8 py-3 group-hover:bg-white group-hover:text-black transition-all\" data-kid=\"167\">Explore Look</button>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"group cursor-pointer\" data-kid=\"168\">\n      <div class=\"relative h-[700px] overflow-hidden mb-8 border border-white/10\" data-kid=\"169\">\n        <div class=\"absolute top-0 left-0 w-full p-8 z-10 pointer-events-none\" data-kid=\"170\">\n          <p class=\"font-cinzel text-5xl leading-none opacity-20 group-hover:opacity-100 transition-opacity\" data-kid=\"171\">03</p>\n          <h3 class=\"font-cinzel text-4xl uppercase tracking-tighter -mt-2 group-hover:text-(--color-crimson) transition-colors\" data-kid=\"172\">Royal<br data-kid=\"173\">Sherwani</h3>\n        </div>\n        <img src=\"https://images.unsplash.com/photo-1622290291468-a28f7a7dc6a8?w=600&h=900&fit=crop\" class=\"w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 brightness-50 group-hover:brightness-100 group-hover:grayscale-0 grayscale\" decoding=\"async\" loading=\"lazy\" data-kid=\"174\">\n        <div class=\"absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black to-transparent\" data-kid=\"175\">\n          <button class=\"font-cinzel uppercase tracking-widest text-sm border border-white px-8 py-3 group-hover:bg-white group-hover:text-black transition-all\" data-kid=\"176\">Explore Look</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"py-24 px-12 bg-(--color-obsidian) border-t border-white/5\" data-kid=\"177\">\n  <div class=\"grid grid-cols-1 md:grid-cols-4 gap-16 mb-24\" data-kid=\"178\">\n    <div class=\"col-span-2\" data-kid=\"179\">\n      <h2 class=\"font-cinzel text-4xl uppercase tracking-widest mb-8\" data-kid=\"180\">Elegance Archive</h2>\n      <p class=\"max-w-md text-white/50 leading-relaxed font-light mb-12\" data-kid=\"181\">\n        A curated collection of cinematic fashion, blending timeless ethnic craftsmanship with a bold, modern aesthetic. Every piece tells a story of romanticism and drama.\n      </p>\n      <div class=\"flex space-x-6\" data-kid=\"182\">\n        <i class=\"ti ti-brand-instagram text-2xl hover:text-(--color-crimson) cursor-pointer\" data-kid=\"183\"></i>\n        <i class=\"ti ti-brand-pinterest text-2xl hover:text-(--color-crimson) cursor-pointer\" data-kid=\"184\"></i>\n        <i class=\"ti ti-brand-youtube text-2xl hover:text-(--color-crimson) cursor-pointer\" data-kid=\"185\"></i>\n      </div>\n    </div>\n    <div data-kid=\"186\">\n      <h4 class=\"font-cinzel uppercase tracking-widest mb-8\" data-kid=\"187\">The Collection</h4>\n      <ul class=\"space-y-4 text-sm font-light text-white/60\" data-kid=\"188\">\n        <li class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"189\">New Arrivals</li>\n        <li class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"190\">Bestsellers</li>\n        <li class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"191\">Bridal Archive</li>\n        <li class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"192\">The Vault</li>\n      </ul>\n    </div>\n    <div data-kid=\"193\">\n      <h4 class=\"font-cinzel uppercase tracking-widest mb-8\" data-kid=\"194\">The Studio</h4>\n      <ul class=\"space-y-4 text-sm font-light text-white/60\" data-kid=\"195\">\n        <li class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"196\">Contact Us</li>\n        <li class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"197\">Shipping & Returns</li>\n        <li class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"198\">Size Guide</li>\n        <li class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"199\">Our Story</li>\n      </ul>\n    </div>\n  </div>\n  <div class=\"text-center pt-12 border-t border-white/5 text-[10px] uppercase tracking-[0.4em] text-white/30\" data-kid=\"200\">\n    © 2026 Elegance Atelier • Designed for the Bold\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"201\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"202\"></script>\n<script data-kid=\"203\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Spotlight Animation\n  gsap.to(\".spotlight-mask\", {\n    scrollTrigger: {\n      trigger: \".hero-section\",\n      start: \"top top\",\n      end: \"bottom top\",\n      scrub: 1,\n    },\n    clipPath: \"circle(100% at 50% 50%)\",\n    ease: \"none\"\n  });\n\n  // Fade in sections\n  const sections = document.querySelectorAll('section');\n  sections.forEach(section => {\n    gsap.from(section.children, {\n      scrollTrigger: {\n        trigger: section,\n        start: \"top 80%\",\n      },\n      y: 50,\n      opacity: 0,\n      duration: 1,\n      stagger: 0.2,\n      ease: \"power2.out\"\n    });\n  });\n</script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"204\">",
