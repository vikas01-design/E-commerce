      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;600&display=swap');\n\n  :root {\n    --color-obsidian: #0A0A0A;\n    --color-crimson: #7A1111;\n    --color-pearl: #FDFBF7;\n  }\n\n  body {\n    background-color: var(--color-obsidian);\n    color: var(--color-pearl);\n    font-family: 'Montserrat', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-cinzel { font-family: 'Cinzel', serif; }\n\n  /* Hero Spotlight Effect */\n  .spotlight-mask {\n    clip-path: circle(25% at 50% 50%);\n    transition: clip-path 0.3s ease-out;\n  }\n\n  /* Arch Layout for Categories */\n  .arch-item:nth-child(1) { transform: translateY(40px); }\n  .arch-item:nth-child(2) { transform: translateY(10px); }\n  .arch-item:nth-child(3) { transform: translateY(0px); }\n  .arch-item:nth-child(4) { transform: translateY(10px); }\n  .arch-item:nth-child(5) { transform: translateY(40px); }\n\n  .arch-item:hover {\n    box-shadow: 0 0 30px 10px rgba(122, 17, 17, 0.6);\n    z-index: 10;\n  }\n\n  /* Pedestal Effect */\n  .pedestal {\n    background: linear-gradient(to top, rgba(122, 17, 17, 0.2), transparent);\n    border-bottom: 2px solid var(--color-crimson);\n  }\n\n  /* Rising Bar Graph for Fast Selling */\n  .rising-demand {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 100%;\n    background-color: var(--color-crimson);\n    opacity: 0.3;\n    transition: height 1s ease-in-out;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: var(--color-obsidian); }\n  ::-webkit-scrollbar-thumb { background: var(--color-crimson); border-radius: 10px; }\n</style>\n\n\n<nav class=\"fixed top-0 left-0 w-full z-50 px-12 py-8 flex justify-between items-center mix-blend-difference\" data-kid=\"1\">\n  <div class=\"text-3xl font-cinzel font-bold tracking-widest uppercase\" data-kid=\"2\">Elegance</div>\n  <div class=\"hidden md:flex space-x-12 text-sm tracking-[0.2em] uppercase font-light\" data-kid=\"3\">\n    <a href=\"#\" class=\"hover:text-(--color-crimson) transition-colors\" data-kid=\"4\">Collections</a>\n    <a href=\"#\" class=\"hover:text-(--color-crimson) transition-colors\" data-kid=\"5\">Bespoke</a>\n    <a href=\"#\" class=\"hover:text-(--color-crimson) transition-colors\" data-kid=\"6\">The Vault</a>\n    <a href=\"#\" class=\"hover:text-(--color-crimson) transition-colors\" data-kid=\"7\">Story</a>\n  </div>\n  <div class=\"flex items-center space-x-8\" data-kid=\"8\">\n    <i class=\"ti ti-search text-xl cursor-pointer\" data-kid=\"9\"></i>\n    <i class=\"ti ti-shopping-bag text-xl cursor-pointer\" data-kid=\"10\"></i>\n  </div>\n</nav>\n\n\n<section class=\"hero-section relative h-screen w-full flex items-center justify-center overflow-hidden\" data-kid=\"11\">\n  \n  <div class=\"absolute inset-0 z-20 pointer-events-none flex items-center justify-center\" data-kid=\"12\">\n    <h1 class=\"font-cinzel text-8xl md:text-9xl text-center uppercase leading-none opacity-80 tracking-tighter\" data-kid=\"13\">\n      The<br data-kid=\"14\">Art of<br data-kid=\"15\">Grace\n    </h1>\n  </div>\n\n  <div class=\"spotlight-mask spotlight-container relative w-full h-full bg-black flex items-center justify-center\" data-kid=\"16\">\n    <video src=\"https://videos.pexels.com/video-files/34391556/14569148_360_640_30fps.mp4\" poster=\"https://images.pexels.com/videos/34391556/pexels-photo-34391556.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover grayscale brightness-50\" data-kid=\"17\"></video>\n    <div class=\"absolute inset-0 bg-(--color-crimson)/10 mix-blend-overlay\" data-kid=\"18\"></div>\n  </div>\n</section>\n\n\n<section class=\"py-32 px-12 bg-(--color-obsidian) relative\" data-kid=\"19\">\n  <div class=\"text-center mb-24\" data-kid=\"20\">\n    <h2 class=\"font-cinzel text